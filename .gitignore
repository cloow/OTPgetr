# ── Secrets / personal data — NEVER commit these ─────────────────────────
# your Anthropic API key (only if you chose the paste option; env var is preferred)
api_key.txt
# your Google OAuth login token
token.json
# token age tracking
token_meta.json
# your personal spam/promo blocklist (senders + codes)
filters.json
# your Google OAuth client (client secret)
credentials.json

# ── Runtime / logs ───────────────────────────────────────────────────────
otpgetr.log
otpgetr.log.*

# ── PyInstaller build output ─────────────────────────────────────────────
build/
dist/
*.spec

# ── Python ───────────────────────────────────────────────────────────────
__pycache__/
*.pyc
.venv/
venv/
.idea/

# MDD audit reports (ephemeral)
.mdd/audits/
# MDD active jobs (ephemeral)
.mdd/jobs/
